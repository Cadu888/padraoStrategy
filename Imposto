interface Imposto {
    public double valorImposto(double valorBase);
}

public class IR implements Imposto {
    
    double valorImposto(double valorBase) {
         return (valorBase * 3) / 100;
    }
}

public class IPTU implements Imposto {
    
    double valorImposto(double valorBase) {
         return (valorBase * 1.5) / 100;
    }
}

public class IPVA implements Imposto {
    
    double valorImposto(double valorBase) {
         return (valorBase * 2.33) / 100;
    }
}